# ── Telegram ────────────────────────────────
BOT_TOKEN=              # Токен от @BotFather
WEBHOOK_URL=https://your-domain.com   # Публичный URL (без /webhook на конце)

# ── PostgreSQL ──────────────────────────────
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/goslog_navigator
# Временный fallback ORM create_all (лучше оставить false и использовать Alembic)
# DB_CREATE_ALL_FALLBACK=false

# ── Redis (FSM storage) ────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ofdata / FNS (wizard + проверка ИНН) ───
# FNS_API_KEY=
# FNS_API_BASE_URL=https://api.ofdata.ru/v2

# ── Публичная проверка ГосЛог (модуль 3) ───
# GOSLOG_PUBLIC_CHECK_URL=https://goslog.ru/check

# ── Утренние алерты APScheduler ─────────────
# DAILY_ALERTS_ENABLED=true
# DAILY_ALERTS_HOUR=9
# DAILY_ALERTS_MINUTE=0
# DAILY_ALERTS_TIMEZONE=Europe/Moscow

# ── YooKassa (модуль 4) ─────────────────────
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=https://your-domain.com/payment/return

# ── Приложение ──────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

