# ── Telegram ────────────────────────────────
BOT_TOKEN=123456:ABC-DEF              # Токен от @BotFather
WEBHOOK_URL=https://your-domain.com   # Публичный URL (без /webhook на конце)
TELEGRAM_PROXY_URL=                   # например http://127.0.0.1:10809

# ── Ofdata / FNS ────────────────────────────
# API ключ из личного кабинета Ofdata (https://ofdata.ru/user/account/api)
FNS_API_KEY=
FNS_API_BASE_URL=https://api.ofdata.ru/v2
FNS_HTTP_TIMEOUT_SEC=15

# ── PostgreSQL ──────────────────────────────
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/goslog_navigator

# ── Redis (FSM storage) ────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PDF (временные файлы) ─────────────────
PDF_TEMP_DIR=goslog_navigator_bot/bot/temp_pdfs
PDF_DELETE_AFTER_SEND=false

# ── Приложение ──────────────────────────────
BOT_MODE=webhook                         # webhook | polling
DEBUG=false
LOG_LEVEL=INFO
